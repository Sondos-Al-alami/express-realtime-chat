# Server
NODE_ENV=development
PORT=3000

# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/chatdb"

# JWT (required)
JWT_SECRET="your-secret-key-at-least-32-chars"
JWT_EXPIRES_IN=7d

# CORS - frontend origin(s), comma-separated for multiple
CORS_ORIGIN=http://localhost:3001

# Optional: public API base URL. When set, upload response fileUrl is full URL (e.g. https://your-api.railway.app/uploads/...).
# PUBLIC_API_URL=https://your-api.railway.app

# File uploads
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880

# Rate limiting (applied to /api/*)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: logging
# LOG_LEVEL=info
